#!/data/data/com.termux/files/usr/bin/bash

DDS_DIR="$HOME/dds"
MYSQL_PID_FILE="/data/data/com.termux/files/usr/var/run/mariadb.pid"
APACHE_PORT=8080
APACHE_SSL_PORT=8443
HTDOCS_DIR="/sdcard/htdocs"
PREFIX="/data/data/com.termux/files/usr"

USE_UI=false
if command -v node &>/dev/null && [ -f "$DDS_DIR/dds-ui/package.json" ]; then
  if [ ! -d "$DDS_DIR/dds-ui/node_modules" ]; then
    echo "Installing dds-ui dependencies..." >&2
    (cd "$DDS_DIR/dds-ui" && npm install --no-audit --no-fund) &>/dev/null
  fi
  USE_UI=true
fi

if $USE_UI; then
  exec node "$DDS_DIR/dds-ui/index.js" "$@"
fi

die() {
  echo "ERROR: $*" >&2
  exit 1
}

ensure_htdocs() {
  [ -d "$HTDOCS_DIR" ] || mkdir -p "$HTDOCS_DIR"
}

apache_running() {
  pgrep httpd >/dev/null 2>&1
}

mysql_pid() {
  if [ -f "$MYSQL_PID_FILE" ]; then
    cat "$MYSQL_PID_FILE"
  fi
}

mysql_running() {
  local pid
  pid=$(mysql_pid)
  [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null
}

case "${1:-help}" in
start)
  ensure_htdocs
  echo "Starting Apache.."
  if apache_running; then
    echo "  Apache already running on port $APACHE_PORT"
  elif apachectl start 2>/dev/null; then
    echo "  Apache started on port $APACHE_PORT"
  else
    die "Apache failed to start. Check $PREFIX/var/log/apache2/error_log"
  fi
  echo "Starting MariaDB.."
  if mysql_running; then
    echo "  MariaDB already running"
  else
    mariadbd-safe --pid-file="$MYSQL_PID_FILE" &
    for i in 1 2 3 4 5; do
      sleep 2
      mysql_running && break
    done
    if mysql_running; then
      echo "  MariaDB started (PID $(mysql_pid))"
    else
      echo "  WARNING: MariaDB may not have started. Check logs."
    fi
  fi
  echo "Open browser: http://localhost:$APACHE_PORT/"
  termux-open-url "http://localhost:$APACHE_PORT/"
  ;;
start-ssl)
  ensure_htdocs
  CERT="$PREFIX/etc/apache2/server.crt"
  KEY="$PREFIX/etc/apache2/server.key"
  if ! openssl x509 -checkend 86400 -noout -in "$CERT" 2>/dev/null; then
    echo "SSL certificate has expired or is missing."
    echo "Creating a new self-signed certificate.."
    openssl req -x509 -newkey rsa:2048 -keyout "$HOME/server.key" \
      -out "$HOME/server.crt" -days 365 -nodes -subj '/CN=localhost'
    mv -f "$HOME/server.crt" "$CERT"
    mv -f "$HOME/server.key" "$KEY"
  fi
  echo "Starting Apache with SSL.."
  if apache_running; then
    apachectl restart 2>/dev/null || die "Apache restart failed"
  else
    apachectl start 2>/dev/null || die "Apache failed to start"
  fi
  echo "  Apache running on ports $APACHE_PORT (HTTP) and $APACHE_SSL_PORT (HTTPS)"
  echo "Starting MariaDB.."
  if mysql_running; then
    echo "  MariaDB already running"
  else
    mariadbd-safe --pid-file="$MYSQL_PID_FILE" &
    for i in 1 2 3 4 5; do
      sleep 2
      mysql_running && break
    done
    mysql_running && echo "  MariaDB started (PID $(mysql_pid))"
  fi
  echo "Open browser: https://localhost:$APACHE_SSL_PORT/"
  termux-open-url "https://localhost:$APACHE_SSL_PORT/"
  ;;
stop)
  echo "Stopping Apache.."
  if apache_running; then
    apachectl stop 2>/dev/null && echo "  Apache stopped" || echo "  Failed to stop Apache"
  else
    echo "  Apache was not running"
  fi
  echo "Stopping MariaDB.."
  if mysql_running; then
    kill "$(mysql_pid)" 2>/dev/null
    rm -f "$MYSQL_PID_FILE"
    echo "  MariaDB stopped"
  elif pgrep mariadb >/dev/null 2>&1; then
    pkill mariadb 2>/dev/null
    echo "  MariaDB stopped (via pkill)"
  else
    echo "  MariaDB was not running"
  fi
  ;;
restart)
  "$0" stop
  sleep 1
  "$0" start
  ;;
status)
  echo "=== DDS Status ==="
  echo ""
  if apache_running; then
    echo "  Apache     RUNNING  ($(pgrep -c httpd) processes, port $APACHE_PORT)"
  else
    echo "  Apache     STOPPED"
  fi
  if mysql_running; then
    echo "  MariaDB    RUNNING  (PID $(mysql_pid))"
  elif pgrep mariadb >/dev/null 2>&1; then
    echo "  MariaDB    RUNNING  (no PID file)"
  else
    echo "  MariaDB    STOPPED"
  fi
  if [ -f "$HTDOCS_DIR/phpmyadmin/index.php" ]; then
    echo "  phpMyAdmin INSTALLED  (/phpmyadmin/)"
  else
    echo "  phpMyAdmin MISSING    (run setup again)"
  fi
  echo ""
  echo "  Document root: $HTDOCS_DIR"
  echo "  HTTP:  http://localhost:$APACHE_PORT/"
  echo "  HTTPS: https://localhost:$APACHE_SSL_PORT/"
  ;;
update)
  if [ ! -d "$DDS_DIR" ]; then
    echo "DDS directory not found. Cloning.."
    git clone "https://github.com/dzshowrav/DZDEV-SERVER-dds.git" "$DDS_DIR" || die "Clone failed"
  fi
  cd "$DDS_DIR" || die "Cannot enter $DDS_DIR"
  git remote update 2>/dev/null
  STATUS=$(git status -uno | grep 'Your branch is up to date')
  echo "Checking for updates.."
  if [ -z "$STATUS" ]; then
    git reset --hard HEAD
    git pull
    bash update
  else
    echo -e "\033[0;33mAlready up to date.\033[0m"
  fi
  ;;
uninstall)
  echo ""
  echo "  Are you absolutely sure?"
  echo ""
  echo "  This action will permanently delete all webserver data"
  echo "  (Apache, MySQL/MariaDB, PHP, Composer) and cannot be undone."
  echo ""
  read -p "  Do you want to continue? (y/N) " REPLY
  if [ "$REPLY" = "y" ] || [ "$REPLY" = "Y" ]; then
    "$0" stop 2>/dev/null
    rm -f "$CERT" "$KEY" "$MYSQL_PID_FILE"
    apt purge apache2 php openssl-tool mariadb -y
    apt autoremove -y
    cd "$HOME" && rm -rf dds "$PREFIX/bin/dds"
    echo "DDS has been successfully uninstalled."
  else
    echo "Abort."
  fi
  ;;
help|*)
  echo "DDS (Termux, Apache, MariaDB, PHP) v1.0"
  echo "github.com/dzshowrav/DZDEV-SERVER-dds"
  echo ""
  echo "Commands:"
  echo "  start           Start DDS (HTTP port $APACHE_PORT)"
  echo "  start-ssl       Start DDS with SSL (HTTPS port $APACHE_SSL_PORT)"
  echo "  stop            Stop DDS"
  echo "  restart         Restart DDS"
  echo "  status          Show service status"
  echo "  update          Update DDS"
  echo "  uninstall       Uninstall DDS"
  ;;
esac
